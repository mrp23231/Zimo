rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields:
    //   - uid: string (required)
    //   - displayName: string (required)
    //   - email: string (required)
    //   - photoURL: string (optional)
    //   - bio: string (optional)
    //   - createdAt: timestamp (required)
    //
    // Collection: posts
    // Fields:
    //   - authorUid: string (required)
    //   - authorName: string (required)
    //   - authorPhoto: string (optional)
    //   - content: string (required, max 1000 chars)
    //   - createdAt: timestamp (required)
    //   - likes: number (required)
    //
    // Collection: messages
    // Fields:
    //   - senderUid: string (required)
    //   - receiverUid: string (required)
    //   - text: string (required, max 500 chars)
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName', 'email', 'createdAt']) &&
             data.uid == request.auth.uid &&
             data.displayName is string && data.displayName.size() > 0 && data.displayName.size() < 50 &&
             data.email is string &&
             !('verified' in data) &&
             !('verifiedAt' in data);
    }

    function followDocId(followerUid, followingUid) {
      return followerUid + '_' + followingUid;
    }

    function isApprovedFollower(viewerUid, authorUid) {
      return exists(/databases/$(database)/documents/follows/$(followDocId(viewerUid, authorUid))) &&
        get(/databases/$(database)/documents/follows/$(followDocId(viewerUid, authorUid))).data.status == 'approved';
    }

    function isPrivateAccount(uid) {
      return exists(/databases/$(database)/documents/users/$(uid)) &&
        get(/databases/$(database)/documents/users/$(uid)).data.isPrivate == true;
    }

    function desiredPostVisibility(authorUid) {
      return isPrivateAccount(authorUid) ? 'followers' : 'public';
    }

    function isPublicPost(data) {
      // Back-compat: if `visibility` is missing, derive it from the author's current privacy setting.
      return (('visibility' in data) && data.visibility == 'public') ||
        (!('visibility' in data) && desiredPostVisibility(data.authorUid) == 'public');
    }

    function isFollowersPost(data) {
      return (('visibility' in data) && data.visibility == 'followers') ||
        (!('visibility' in data) && desiredPostVisibility(data.authorUid) == 'followers');
    }

    function canReadPost(data) {
      return isAuthenticated() && (
        request.auth.uid == data.authorUid ||
        isPublicPost(data) ||
        (isFollowersPost(data) && isApprovedFollower(request.auth.uid, data.authorUid))
      );
    }

    function hasMedia(data) {
      return (('imageUrls' in data) && (data.imageUrls is list) && data.imageUrls.size() > 0) ||
             (('imageUrl' in data) && (data.imageUrl is string) && data.imageUrl.size() > 0);
    }

    function isValidPost(data) {
      // Allow posts with either non-empty text OR media (imageUrls/imageUrl).
      // This matches the app UX where a user can publish "photo-only" posts.
      return data.keys().hasAll(['authorUid', 'authorName', 'content', 'createdAt', 'likes', 'likedBy']) &&
             data.authorUid == request.auth.uid &&
             data.content is string && data.content.size() <= 1000 &&
             (data.content.size() > 0 || hasMedia(data)) &&
             data.likes is number &&
             data.likedBy is list &&
             (!('visibility' in data) || (data.visibility is string && (data.visibility == 'public' || data.visibility == 'followers'))) &&
             (!('imageUrls' in data) || data.imageUrls is list) &&
             (!('imageUrl' in data) || data.imageUrl is string) &&
             (!('hiddenFrom' in data) || data.hiddenFrom is list);
    }

    function isValidComment(data) {
      return data.keys().hasAll(['authorUid', 'authorName', 'text', 'createdAt']) &&
             data.authorUid == request.auth.uid &&
             data.text is string && data.text.size() > 0 && data.text.size() <= 500;
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['senderUid', 'receiverUid', 'text', 'createdAt']) &&
             data.senderUid == request.auth.uid &&
             data.text is string && data.text.size() <= 500 &&
             (
               (data.text.size() > 0) ||
               (('imageUrl' in data) && data.imageUrl is string) ||
               (('stickerUrl' in data) && data.stickerUrl is string) ||
               (('audioUrl' in data) && data.audioUrl is string) ||
               (('audioPath' in data) && data.audioPath is string)
             );
    }

    function hasField(data, key) {
      return key in data;
    }

    function safeLikeUpdate(beforeData, afterData) {
      // Allows toggling the viewer's own like only and keeps `likes` in sync with list size.
      //
      // Supports back-compat docs that may not have likes/likedBy yet by treating missing as 0/[].
      let beforeLikedBy = (hasField(beforeData, 'likedBy') && beforeData.likedBy is list) ? beforeData.likedBy : [];
      let afterLikedBy = (hasField(afterData, 'likedBy') && afterData.likedBy is list) ? afterData.likedBy : [];
      let beforeLikes = (hasField(beforeData, 'likes') && beforeData.likes is number) ? beforeData.likes : 0;
      let afterLikes = (hasField(afterData, 'likes') && afterData.likes is number) ? afterData.likes : afterLikedBy.size();

      return afterLikes == afterLikedBy.size() &&
        beforeLikes == beforeLikedBy.size() &&
        (
          // like
          (afterLikedBy.size() == beforeLikedBy.size() + 1 &&
            afterLikedBy.hasAll(beforeLikedBy) &&
            afterLikedBy.hasAny([request.auth.uid]) &&
            !beforeLikedBy.hasAny([request.auth.uid])
          ) ||
          // unlike
          (afterLikedBy.size() == beforeLikedBy.size() - 1 &&
            beforeLikedBy.hasAll(afterLikedBy) &&
            beforeLikedBy.hasAny([request.auth.uid]) &&
            !afterLikedBy.hasAny([request.auth.uid])
          )
        );
    }

    function isValidFollow(data) {
      return data.keys().hasAll(['followerUid', 'followingUid', 'status', 'createdAt']) &&
        data.followerUid == request.auth.uid &&
        data.followingUid is string && data.followingUid.size() > 0 &&
        data.status is string && (data.status == 'pending' || data.status == 'approved' || data.status == 'rejected');
    }

    function isValidNotification(data) {
      return data.keys().hasAll(['type', 'fromUid', 'toUid', 'createdAt', 'read']) &&
        data.fromUid == request.auth.uid &&
        data.toUid is string && data.toUid.size() > 0 &&
        data.type is string && data.type.size() > 0 &&
        data.read is bool;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) &&
        // prevent identity swaps
        request.resource.data.uid == resource.data.uid &&
        request.resource.data.email == resource.data.email &&
        request.resource.data.createdAt == resource.data.createdAt &&
        // prevent self-verification / privilege escalation
        (!('verified' in request.resource.data) || request.resource.data.verified == resource.data.verified) &&
        (!('verifiedAt' in request.resource.data) || request.resource.data.verifiedAt == resource.data.verifiedAt);

      // Allow admins to manage verification fields only.
      allow update: if isAdmin() &&
        request.resource.data.uid == resource.data.uid &&
        request.resource.data.email == resource.data.email &&
        request.resource.data.createdAt == resource.data.createdAt &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['verified', 'verifiedAt']);
    }

    match /posts/{postId} {
      allow read: if canReadPost(resource.data);
      allow create: if isAuthenticated() &&
        isValidPost(request.resource.data) &&
        // Enforce that `visibility` matches the author's current privacy setting.
        request.resource.data.visibility == desiredPostVisibility(request.auth.uid);
      allow update: if isAuthenticated() && (
        (request.auth.uid == resource.data.authorUid &&
          isValidPost(request.resource.data) &&
          request.resource.data.visibility == desiredPostVisibility(request.auth.uid)
        ) ||
        // Profile sync: allow the post author to update display fields without editing the post body.
        (
          request.auth.uid == resource.data.authorUid &&
          request.resource.data.authorUid == resource.data.authorUid &&
          request.resource.data.visibility == resource.data.visibility &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'authorName',
            'authorPhoto',
            'authorUsername',
            'authorVerified'
          ])
        ) ||
        // Admins may sync verification badge display on existing posts.
        (
          isAdmin() &&
          request.resource.data.authorUid == resource.data.authorUid &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['authorVerified'])
        ) ||
        (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'likedBy']) &&
          safeLikeUpdate(resource.data, request.resource.data)
        )
      );
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.authorUid;

      match /comments/{commentId} {
        function postDoc() {
          return get(/databases/$(database)/documents/posts/$(postId));
        }

        allow read: if isAuthenticated() &&
          postDoc().exists() &&
          canReadPost(postDoc().data);

        allow create: if isAuthenticated() &&
          postDoc().exists() &&
          canReadPost(postDoc().data) &&
          isValidComment(request.resource.data);

        allow update: if isAuthenticated() && (
          // like/unlike
          (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'likedBy']) &&
            safeLikeUpdate(resource.data, request.resource.data)
          ) ||
          // author edit (optional)
          (request.auth.uid == resource.data.authorUid && isValidComment(request.resource.data))
        );

        allow delete: if isAuthenticated() &&
          (request.auth.uid == resource.data.authorUid ||
           (postDoc().exists() && request.auth.uid == postDoc().data.authorUid));
      }
    }

    match /follows/{followId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidFollow(request.resource.data);
      allow update: if isAuthenticated() && (
        // Profile owner approves/rejects.
        (
          request.auth.uid == resource.data.followingUid &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']) &&
          (request.resource.data.status == 'approved' || request.resource.data.status == 'rejected' || request.resource.data.status == 'pending')
        ) ||
        // Follower toggles notifications for this author.
        (
          request.auth.uid == resource.data.followerUid &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['postNotifications']) &&
          request.resource.data.postNotifications is bool
        )
      );

      allow delete: if isAuthenticated() &&
        (request.auth.uid == resource.data.followerUid || request.auth.uid == resource.data.followingUid);
    }

    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && request.auth.uid == resource.data.toUid;
      allow create: if isAuthenticated() && isValidNotification(request.resource.data);
      allow update: if isAuthenticated() && request.auth.uid == resource.data.toUid && 
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.toUid;
    }

    match /reports/{reportId} {
      // Allow users to report content; do not expose reports to clients by default.
      allow create: if isAuthenticated() &&
        request.resource.data.keys().hasAll(['postId', 'reporterUid', 'authorUid', 'createdAt', 'status']) &&
        request.resource.data.reporterUid == request.auth.uid &&
        request.resource.data.status == 'pending';
      allow read: if isAdmin();
      allow update: if isAdmin() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'reviewedAt', 'reviewedBy']);
      allow delete: if isAdmin();
    }

    match /verificationRequests/{uid} {
      allow read: if isAuthenticated() &&
        (request.auth.uid == uid || (resource.data.uid == request.auth.uid) || isAdmin());

      // Users can create/refresh their own request doc (id == uid).
      allow create, update: if isAuthenticated() &&
        request.auth.uid == uid &&
        request.resource.data.keys().hasAll(['uid', 'displayName', 'createdAt', 'status']) &&
        request.resource.data.keys().hasOnly(['uid', 'displayName', 'createdAt', 'status', 'category', 'reason', 'evidenceLinks']) &&
        request.resource.data.uid == request.auth.uid &&
        request.resource.data.displayName is string &&
        request.resource.data.status == 'pending' &&
        (!('category' in request.resource.data) || request.resource.data.category is string) &&
        (!('reason' in request.resource.data) || request.resource.data.reason is string) &&
        (!('evidenceLinks' in request.resource.data) || (request.resource.data.evidenceLinks is list && request.resource.data.evidenceLinks.size() <= 3));

      allow delete: if isAdmin();

      // Admins can approve/reject (and optionally stamp verifiedAt on the user doc separately).
      allow update: if isAdmin();
    }

    match /admins/{uid} {
      // Allows a user to check their own admin status without revealing others.
      allow read: if isAuthenticated() && request.auth.uid == uid;
      allow write: if false;
    }

    match /config/{docId} {
      // Public read so the app can show maintenance screen before login.
      allow read: if true;
      allow write: if isAdmin();
    }

    match /announcements/{announcementId} {
      // Public read so everyone can see announcements.
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /messages/{messageId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.senderUid || request.auth.uid == resource.data.receiverUid);
      allow create: if isAuthenticated() && isValidMessage(request.resource.data);

      allow update: if isAuthenticated() &&
        (request.auth.uid == resource.data.senderUid || request.auth.uid == resource.data.receiverUid) &&
        // Keep updates scoped to chat features used in the app.
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'read',
          'text',
          'editedAt',
          'deletedFor',
          'deletedForAll',
          'imageUrl',
          'audioUrl',
          'audioPath',
          'audioState',
          'audioMime',
          'audioDurationMs',
          'replyToId',
          'replyToText',
          'replyToSenderName',
          'pinned',
          'reactions'
        ]);
    }
  }
}
