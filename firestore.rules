rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields:
    //   - uid: string (required)
    //   - displayName: string (required)
    //   - email: string (required)
    //   - photoURL: string (optional)
    //   - bio: string (optional)
    //   - createdAt: timestamp (required)
    //
    // Collection: posts
    // Fields:
    //   - authorUid: string (required)
    //   - authorName: string (required)
    //   - authorPhoto: string (optional)
    //   - content: string (required, max 1000 chars)
    //   - createdAt: timestamp (required)
    //   - likes: number (required)
    //
    // Collection: messages
    // Fields:
    //   - senderUid: string (required)
    //   - receiverUid: string (required)
    //   - text: string (required, max 500 chars)
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName', 'email', 'createdAt']) &&
             data.uid == request.auth.uid &&
             data.displayName is string && data.displayName.size() > 0 && data.displayName.size() < 50 &&
             data.email is string;
    }

    function isPrivateAccount(uid) {
      return exists(/databases/$(database)/documents/users/$(uid)) &&
        get(/databases/$(database)/documents/users/$(uid)).data.isPrivate == true;
    }

    function followDocId(followerUid, followingUid) {
      return followerUid + '_' + followingUid;
    }

    function isApprovedFollower(viewerUid, authorUid) {
      return exists(/databases/$(database)/documents/follows/$(followDocId(viewerUid, authorUid))) &&
        get(/databases/$(database)/documents/follows/$(followDocId(viewerUid, authorUid))).data.status == 'approved';
    }

    function canViewUserContent(authorUid) {
      return isAuthenticated() && (
        request.auth.uid == authorUid ||
        !isPrivateAccount(authorUid) ||
        isApprovedFollower(request.auth.uid, authorUid)
      );
    }

    function notHiddenFrom(data) {
      return !('hiddenFrom' in data) || !(data.hiddenFrom is list) || !data.hiddenFrom.hasAny([request.auth.uid]);
    }

    function isValidPost(data) {
      return data.keys().hasAll(['authorUid', 'authorName', 'content', 'createdAt', 'likes', 'likedBy']) &&
             data.authorUid == request.auth.uid &&
             data.content is string && data.content.size() > 0 && data.content.size() <= 1000 &&
             data.likes is number &&
             data.likedBy is list &&
             (!('imageUrls' in data) || data.imageUrls is list) &&
             (!('imageUrl' in data) || data.imageUrl is string) &&
             (!('hiddenFrom' in data) || data.hiddenFrom is list);
    }

    function isValidComment(data) {
      return data.keys().hasAll(['authorUid', 'authorName', 'text', 'createdAt']) &&
             data.authorUid == request.auth.uid &&
             data.text is string && data.text.size() > 0 && data.text.size() <= 500;
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['senderUid', 'receiverUid', 'text', 'createdAt']) &&
             data.senderUid == request.auth.uid &&
             data.text is string && data.text.size() <= 500 &&
             (
               (data.text.size() > 0) ||
               (('imageUrl' in data) && data.imageUrl is string) ||
               (('audioUrl' in data) && data.audioUrl is string)
             );
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) &&
        // prevent identity swaps
        request.resource.data.uid == resource.data.uid &&
        request.resource.data.email == resource.data.email &&
        request.resource.data.createdAt == resource.data.createdAt;
    }

    match /posts/{postId} {
      allow read: if isAuthenticated() &&
        canViewUserContent(resource.data.authorUid) &&
        notHiddenFrom(resource.data);
      allow create: if isAuthenticated() && isValidPost(request.resource.data);
      allow update: if isAuthenticated() && (
        (request.auth.uid == resource.data.authorUid && isValidPost(request.resource.data)) ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'likedBy']))
      );
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.authorUid;

      match /comments/{commentId} {
        function postDoc() {
          return get(/databases/$(database)/documents/posts/$(postId));
        }

        allow read: if isAuthenticated() &&
          postDoc().exists() &&
          canViewUserContent(postDoc().data.authorUid) &&
          notHiddenFrom(postDoc().data);

        allow create: if isAuthenticated() &&
          postDoc().exists() &&
          canViewUserContent(postDoc().data.authorUid) &&
          notHiddenFrom(postDoc().data) &&
          isValidComment(request.resource.data);

        allow update: if isAuthenticated() && (
          // like/unlike
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'likedBy']) ||
          // author edit (optional)
          (request.auth.uid == resource.data.authorUid && isValidComment(request.resource.data))
        );

        allow delete: if isAuthenticated() &&
          (request.auth.uid == resource.data.authorUid ||
           (postDoc().exists() && request.auth.uid == postDoc().data.authorUid));
      }
    }

    match /follows/{followId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.followerUid;
      allow update: if isAuthenticated() && (
        // Profile owner approves/rejects.
        (
          request.auth.uid == resource.data.followingUid &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']) &&
          (request.resource.data.status == 'approved' || request.resource.data.status == 'rejected' || request.resource.data.status == 'pending')
        ) ||
        // Follower toggles notifications for this author.
        (
          request.auth.uid == resource.data.followerUid &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['postNotifications']) &&
          request.resource.data.postNotifications is bool
        )
      );

      allow delete: if isAuthenticated() &&
        (request.auth.uid == resource.data.followerUid || request.auth.uid == resource.data.followingUid);
    }

    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && request.auth.uid == resource.data.toUid;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && request.auth.uid == resource.data.toUid && 
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.toUid;
    }

    match /messages/{messageId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.senderUid || request.auth.uid == resource.data.receiverUid);
      allow create: if isAuthenticated() && isValidMessage(request.resource.data);

      allow update: if isAuthenticated() &&
        (request.auth.uid == resource.data.senderUid || request.auth.uid == resource.data.receiverUid) &&
        // Keep updates scoped to chat features used in the app.
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'read',
          'text',
          'editedAt',
          'deletedFor',
          'deletedForAll',
          'imageUrl',
          'audioUrl',
          'audioDurationMs',
          'replyToId',
          'replyToText',
          'replyToSenderName',
          'pinned',
          'reactions'
        ]);
    }
  }
}
